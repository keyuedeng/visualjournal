generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entry {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(255)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  insight   Insight?
}

model Insight {
  id        String   @id @default(cuid())
  entryId   String   @unique
  topics    String[]
  sentiment Float
  emotions  String[]
  createdAt DateTime @default(now())

  entry Entry @relation(fields: [entryId], references: [id])
}

model IdentityNode {
  id String @id @default(cuid())
  userId String
  label String
  category String
  strength Float
  ring Int? 

  outgoing IdentityEdge[] @relation("NodeOutgoing")
  incoming IdentityEdge[] @relation("NodeIncoming")

  insights IdentityNodeInsight[]
}

model IdentityEdge {
  id String @id
  userId String
  sourceId String
  targetId String
  weight Float
  
  source IdentityNode @relation("NodeOutgoing", fields: [sourceId], references: [id])
  target IdentityNode @relation("NodeIncoming", fields: [targetId], references: [id])
}

model IdentityNodeInsight {
  id String @id @default(cuid())
  userId String
  nodeId String
  summary String?
  notes String?
  excerpts String[]
  updatedAt DateTime @updatedAt

  node IdentityNode @relation(fields: [nodeId], references: [id])

  @@index([userId])
  @@index([nodeId])
}